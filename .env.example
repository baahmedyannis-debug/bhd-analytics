# ═══════════════════════════════════════
# BHD Analytics — Variables d'environnement
# Copier en .env.local et remplir les valeurs
# ═══════════════════════════════════════

# ── Instagram (Meta Graph API) ────────
# https://developers.facebook.com/apps/
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# ── Spotify (Web API) ─────────────────
# https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_ARTIST_ID=

# ── YouTube (Data API v3) ─────────────
# https://console.cloud.google.com/apis
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# ── SoundCloud ────────────────────────
# https://soundcloud.com/you/apps
SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_USER_ID=

# ── TikTok ────────────────────────────
# https://developers.tiktok.com/
TIKTOK_ACCESS_TOKEN=

# ── Shotgun ───────────────────────────
# https://shotgun.live (compte promoteur)
SHOTGUN_API_KEY=
SHOTGUN_PROMOTER_ID=
